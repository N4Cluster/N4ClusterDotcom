# N4Cluster website — environment variables
# Copy to `.env.local` for local dev, and set the same keys in the Vercel
# project (Production + Preview scopes). Without the GMAIL_* keys, the contact
# and newsletter forms will fail at runtime (HTTP 500) and submissions are lost.

# ─── Lead notification email (Gmail API, OAuth2) ──────────────────────────────
# The Google account submissions are SENT FROM.
GMAIL_USER=contact@n4cluster.com
# OAuth2 credentials for that account (Google Cloud console + OAuth playground).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Where contact/newsletter submissions are DELIVERED TO.
# Optional — defaults to contact@n4cluster.com if unset.
CONTACT_RECIPIENT=contact@n4cluster.com

# ─── ICP Finder (lead enrichment / CRM) ───────────────────────────────────────
# If ICP_FINDER_API_URL is unset, the ICP POST is skipped (email still sends).
ICP_FINDER_API_URL=
ICP_FINDER_API_KEY=

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
